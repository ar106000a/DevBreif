{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" },
    {
      "source": "/api/:path*",
      "destination": "https://devbrief-backend.onrender.com//api/:path*"
    },
    {
      "source": "/app/:path*",
      "destination": "https://devbrief-backend.onrender.com//app/:path*"
    }
  ]
}
